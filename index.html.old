<!-- ============== BLUEPRINT ============== -->
<section class="section" style="background: var(--bg-muted);">
  <div class="container">
    <div style="display: flex; justify-content: space-between; align-items: flex-end; gap: var(--s-6); flex-wrap: wrap; margin-bottom: var(--s-7);">
      <div style="max-width: 56ch;">
        <div class="t-eyebrow reveal"><span class="dot"></span>The Blueprint</div>
        <h2 class="t-display reveal" style="margin: 16px 0 16px;">How an engagement actually runs.</h2>
        <p class="t-muted reveal" style="font-size: 1.0625rem;">
          The same four steps inside every programme. Different work, same accountability.
        </p>
      </div>
      <a href="blueprint.html" class="btn btn-outline reveal">
        Read the full Blueprint
        <svg class="arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>

    <div class="blueprint reveal">
      <div class="bp-step">
        <div class="step-n">01</div>
        <div class="step-name">Diagnose</div>
        <div class="step-desc">Map the gap. Start with the work the organisation needs to do, and the capability gaps standing in the way.</div>
        <svg class="glyph" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="26" cy="26" r="18"/><path d="M40 40l16 16"/></svg>
      </div>
      <div class="bp-step">
        <div class="step-n">02</div>
        <div class="step-name">Design</div>
        <div class="step-desc">Build the programme. Tailored from expert-led instruction, authorised content, and the right modality mix.</div>
        <svg class="glyph" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="8" y="8" width="48" height="48"/><path d="M8 24h48M24 8v48"/></svg>
      </div>
      <div class="bp-step">
        <div class="step-n">03</div>
        <div class="step-name">Deliver</div>
        <div class="step-desc">Run it human-led. In-person and virtual, hands-on, with coaching and reinforcement from real-world experts.</div>
        <svg class="glyph" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="32" cy="20" r="10"/><path d="M12 56c0-11 9-20 20-20s20 9 20 20"/></svg>
      </div>
      <div class="bp-step">
        <div class="step-n">04</div>
        <div class="step-name">Prove</div>
        <div class="step-desc">Measure capability. Close the loop on whether people can do the work — and stand behind the outcome.</div>
        <svg class="glyph" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 48l16-16 12 12 20-20"/><path d="M44 24h12v12"/></svg>
      </div>
    </div>

    <!-- Diagnose CTA -->
    <div style="margin-top: var(--s-6); display: flex; gap: var(--s-4); align-items: center; flex-wrap: wrap;" class="reveal">
      <a href="diagnose.html" class="btn btn-primary">
        Start with Diagnose — 10 minutes
        <svg class="arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
      <span class="t-mono t-subtle" style="font-size: 0.75rem; letter-spacing: 0.06em;">A short capability mapper. No sign-up. You leave with a route.</span>
    </div>
  </div>
</section>

<!-- ============== EXPERTS ============== -->
<section class="section">
  <div class="container">
    <div style="display: flex; justify-content: space-between; align-items: flex-end; gap: var(--s-6); flex-wrap: wrap; margin-bottom: var(--s-7);">
      <div style="max-width: 60ch;">
        <div class="t-eyebrow reveal"><span class="dot"></span>Our real-world experts</div>
        <h2 class="t-display reveal" style="margin: 16px 0 16px;">
          The work is taught by <em style="font-family: var(--font-serif); font-style: italic; font-weight: 400; color: var(--build-600);">the people who do the work.</em>
        </h2>
        <p class="t-muted reveal" style="font-size: 1.0625rem;">
          No trainers reading scripts. Practitioners with 15, 20, 25 years in the field. We name them because their reputation is part of what you're buying.
        </p>
      </div>
      <a href="experts.html" class="btn btn-outline reveal">
        Meet all 240 experts
        <svg class="arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>

    <div class="grid cols-4">
      <article class="expert-card reveal">
        <div class="ec-portrait">
          <!-- Stylised abstract portrait -->
          <svg viewBox="0 0 200 250" xmlns="http://www.w3.org/2000/svg">
            <defs><linearGradient id="g1" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#0A0E1A"/><stop offset="1" stop-color="#2A3349"/></linearGradient></defs>
            <rect width="200" height="250" fill="#EBE6DB"/>
            <circle cx="100" cy="95" r="44" fill="url(#g1)"/>
            <path d="M30 250 Q100 170 170 250 Z" fill="url(#g1)"/>
            <circle cx="100" cy="95" r="44" fill="none" stroke="#00C896" stroke-width="2" stroke-dasharray="4 8" opacity="0.6"/>
          </svg>
        </div>
        <div class="ec-body">
          <p class="ec-name">Anya Petrov</p>
          <p class="ec-role">Cybersecurity · 22 years</p>
          <p class="ec-bio">CISSP. Former CISO in regulated finance. Teaches Microsoft Security Operations and zero-trust architecture across EMEA.</p>
        </div>
      </article>

